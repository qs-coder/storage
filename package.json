{
  "name": "@qs-coder/storage",
  "type": "module",
  "version": "0.0.0-development",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/qs-coder/storage.git"
  },
  "description": "通用存储能力（local/session/memory/electron/cookie 等统一封装）",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs"
    },
    "./electron": {
      "require": "./dist/electron/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.esm.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c && node scripts/build.cjs",
    "build:types": "tsc -p tsconfig.json --emitDeclarationOnly",
    "build:bytecode": "node scripts/encrypt.cjs",
    "build:electron": "node scripts/build.js",
    "test": "vitest run",
    "prepack": "pnpm build && pnpm build:types"
  },
  "dependencies": {
    "buffer": "^6.0.3",
    "sm-crypto": "^0.3.12"
  },
  "optionalDependencies": {
    "electron-store": "^8.1.0",
    "localforage": "^1.10.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.2.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@semantic-release/changelog": "6",
    "@semantic-release/git": "10",
    "@types/node": "^20.11.19",
    "@types/sm-crypto": "^0.3.4",
    "bytenode": "^1.5.3",
    "electron": "^41.1.0",
    "rollup": "^4.14.0",
    "rollup-plugin-clear": "^2.0.7",
    "semantic-release": "^24.2.9",
    "typescript": "^5.2.2",
    "vitest": "^1.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  }
}